index 000000000..a1f212e69
--- /dev/null
+++ b/tools/qqbot_messaging_tool.py
@@ -0,0 +1,181 @@
+"""Fixed-target QQBot messaging tools for owner/group escalation."""
+
+from __future__ import annotations
+
+import json
+from concurrent.futures import TimeoutError as FutureTimeoutError
+from typing import Any
+
+from gateway.turn_context import get_gateway_turn_context
+from tools.registry import registry, tool_error
+
+_MAX_MESSAGE_LENGTH = 1500
+
+
+def _qqbot_config() -> dict[str, Any]:
+    from hermes_cli.config import load_config
+
+    config = load_config()
+    platforms = config.get("platforms") or {}
+    qqbot = platforms.get("qqbot") or {}
+    extra = qqbot.get("extra") or {}
+    return extra if isinstance(extra, dict) else {}
+
+
+def _single_value(value: Any) -> str:
+    from gateway.platforms.qqbot.utils import coerce_list
+
+    values = coerce_list(value)
+    return values[0] if len(values) == 1 else ""
+
+
+def _extra_value(extra: dict, snake: str, camel: str) -> Any:
+    value = extra.get(snake)
+    return value if value is not None else extra.get(camel)
+
+
+def _live_gateway():
+    from gateway.config import Platform
+    from gateway.run import _gateway_runner_ref
+
+    runner = _gateway_runner_ref()
+    if runner is None:
+        return None, None
+    return runner, runner.adapters.get(Platform.QQBOT)
+
+
+def _send_fixed(chat_id: str, chat_type: str, message: str) -> str:
+    content = str(message or "").strip()
+    if not content:
+        return tool_error("message is required")
+    if len(content) > _MAX_MESSAGE_LENGTH:
+        return tool_error(f"message exceeds {_MAX_MESSAGE_LENGTH} characters")
+
+    runner, adapter = _live_gateway()
+    if adapter is None or runner is None:
+        return tool_error("Live QQBot adapter is unavailable")
+
+    loop = getattr(runner, "_gateway_loop", None)
+    if loop is None or loop.is_closed() or not loop.is_running():
+        return tool_error("Live QQBot gateway event loop is unavailable")
+
+    from agent.async_utils import safe_schedule_threadsafe
+
+    if chat_type == "group":
+        coro = adapter.send(
+            chat_id=chat_id,
+            content=content,
+            metadata={"chat_type": "group"},
+        )
+    elif chat_type == "dm":
+        coro = adapter.send(
+            chat_id=chat_id,
+            content=content,
+            metadata={"chat_type": "c2c"},
+        )
+    else:
+        return tool_error(f"Unsupported chat_type for QQBot: {chat_type}")
+
+    future = safe_schedule_threadsafe(coro, loop)
+    if future is None:
+        return tool_error("Failed to schedule QQBot send on the gateway event loop")
+    try:
+        result = future.result(timeout=45)
+    except FutureTimeoutError:
+        future.cancel()
+        return tool_error(
+            "QQBot send timed out; delivery status is unknown. Do not retry "
+            "automatically because the first message may still have been accepted."
+        )
+    except Exception as exc:
+        return tool_error(f"QQBot send failed: {exc}")
+    if not getattr(result, "success", False):
+        return tool_error(getattr(result, "error", None) or "QQBot send failed")
+    return json.dumps(
+        {
+            "success": True,
+            "message_id": getattr(result, "message_id", None),
+        },
+        ensure_ascii=False,
+    )
+
+
+def qqbot_send_home_group(message: str) -> str:
+    """Allow only the configured owner DM to send into the configured home group."""
+    context = get_gateway_turn_context()
+    if context is None or context.platform != "qqbot" or context.chat_type != "dm":
+        return tool_error("Only the authorized QQBot owner private chat may use this tool")
+
+    extra = _qqbot_config()
+    owner_openid = _single_value(
+        _extra_value(extra, "group_owner_openids", "groupOwnerOpenids")
+    )
+    if not owner_openid or context.user_id != owner_openid:
+        return tool_error("Current QQBot private-chat sender is not the configured owner")
+
+    group_openid = _single_value(
+        _extra_value(extra, "group_allow_from", "groupAllowFrom")
+    )
+    if not group_openid:
+        return tool_error("Exactly one QQBot home group must be configured")
+    return _send_fixed(group_openid, "group", message)
+
+
+def qqbot_notify_owner(message: str) -> str:
+    """Allow a QQBot group turn to escalate a decision to the configured owner DM."""
+    context = get_gateway_turn_context()
+    if context is None or context.platform != "qqbot" or context.chat_type != "group":
+        return tool_error("Only an active QQBot group conversation may notify the owner")
+
+    extra = _qqbot_config()
+    allowed_group = _single_value(
+        _extra_value(extra, "group_allow_from", "groupAllowFrom")
+    )
+    if not allowed_group or context.chat_id != allowed_group:
+        return tool_error("Current QQBot group is not the configured home group")
+
+    owner_openid = _single_value(
+        _extra_value(extra, "group_owner_openids", "groupOwnerOpenids")
+    )
+    if not owner_openid:
+        return tool_error("Exactly one QQBot owner must be configured")
+    return _send_fixed(owner_openid, "dm", message)
+
+
+registry.register(
+    name="qqbot_send_home_group",
+    toolset="qqbot_messaging",
+    schema={
+        "name": "qqbot_send_home_group",
+        "description": (
+            "Send a message to the configured QQBot home group. Available only when "
+            "the configured owner explicitly requests this from the authorized private chat."
+        ),
+        "parameters": {
+            "type": "object",
+            "properties": {"message": {"type": "string"}},
+            "required": ["message"],
+        },
+    },
+    handler=lambda args, **kw: qqbot_send_home_group(args.get("message", "")),
+    emoji="📣",
+)
+
+registry.register(
+    name="qqbot_notify_owner",
+    toolset="qqbot_messaging",
+    schema={
+        "name": "qqbot_notify_owner",
+        "description": (
+            "Privately notify the configured QQBot owner when a home-group situation "
+            "genuinely needs an owner decision, sensitive follow-up, or escalation."
+        ),
+        "parameters": {
+            "type": "object",
+            "properties": {"message": {"type": "string"}},
+            "required": ["message"],
+        },
+    },
+    handler=lambda args, **kw: qqbot_notify_owner(args.get("message", "")),
+    emoji="🔔",
+)
