+def test_send_timeout_cancels_future_and_warns_against_retry(configured):
+    class TimedOutFuture:
+        def __init__(self):
+            self.cancelled = False
+
+        def result(self, timeout):
+            assert timeout == 45
+            raise FutureTimeoutError()
+
+        def cancel(self):
+            self.cancelled = True
+
+    timed_out = TimedOutFuture()
+    token = _context(chat_type="dm", user_id=OWNER, chat_id=OWNER)
+    try:
+        with patch(
+            "agent.async_utils.safe_schedule_threadsafe",
+            return_value=timed_out,
+        ):
+            result = json.loads(qqbot_send_home_group("超时测试"))
+    finally:
+        reset_gateway_turn_context(token)
+
+    assert timed_out.cancelled is True
+    assert "Do not retry automatically" in result["error"]
