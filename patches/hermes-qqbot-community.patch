+    async def _resolve_member_name(
+        self, member_openid: str, *, source: str = "group"
+    ) -> str:
+        """Return a human-readable sender_name for a QQ member/user OpenID.
+
+        Resolution order:
+        1. In-memory cache hit → return immediately.
+        2. Query OIAPI over HTTPS with a short timeout when explicitly enabled.
+        3. Cache successful nicknames for a bounded TTL and failures briefly.
+        4. On any failure (timeout / network / non-JSON / missing nick) return
+           an empty string so the caller can use its own fallback.
+
+        A per-OpenID single-flight task prevents concurrent cache misses from
+        creating duplicate third-party requests.
+        """
+        del source
+        member_openid = str(member_openid or "").strip()
+        if not member_openid:
+            return ""
+
+        now = time.monotonic()
+        async with self._name_cache_lock:
+            cached = self._name_cache.get(member_openid)
+            if cached is not None and cached[1] > now:
+                return cached[0]
+            if cached is not None:
+                self._name_cache.pop(member_openid, None)
+            existing = self._name_lookups.get(member_openid)
+            if existing is None:
+                existing = asyncio.create_task(
+                    self._fetch_member_name(member_openid)
+                )
+                self._name_lookups[member_openid] = existing
+
+        try:
+            return await asyncio.shield(existing)
+        finally:
+            if existing.done():
+                async with self._name_cache_lock:
+                    if self._name_lookups.get(member_openid) is existing:
+                        self._name_lookups.pop(member_openid, None)
+
+    @staticmethod
+    def _sanitize_sender_name(value: Any) -> str:
+        """Flatten untrusted profile text before it enters prompts/logs."""
+        text = " ".join(str(value or "").split())
+        text = "".join(
+            " " if ch in "[]|;" or unicodedata.category(ch) == "Cf" else ch
+            for ch in text
+            if ch.isprintable()
+        )
+        text = " ".join(text.split())
+        return text[:64].strip()
+
+    async def _fetch_member_name(self, member_openid: str) -> str:
+        """Fetch one nickname and populate positive/negative cache."""
+        name = ""
+
+        if self._http_client and self._nickname_lookup_enabled:
+            try:
+                resp = await self._http_client.get(
+                    "https://www.oiapi.net/api/Openid",
+                    params={"openid": member_openid, "appid": self._app_id},
+                    timeout=self._oiapi_timeout,
+                )
+                if resp.status_code == 200:
+                    body = resp.json()
+                    if isinstance(body, dict) and body.get("code") == 1:
+                        data = body.get("data")
+                        if isinstance(data, dict):
+                            name = self._sanitize_sender_name(data.get("nickname"))
+            except Exception as exc:
+                logger.debug("[%s] QQ nickname lookup failed: %s", self._log_tag, exc)
+
+        ttl = self._oiapi_cache_ttl if name else self._oiapi_negative_ttl
+        async with self._name_cache_lock:
+            self._name_cache[member_openid] = (name, time.monotonic() + ttl)
+        return name
