--- /dev/null
+++ b/gateway/turn_context.py
@@ -0,0 +1,46 @@
+"""Concurrency-safe identity context for the active gateway agent turn."""
+
+from __future__ import annotations
+
+from contextvars import ContextVar, Token
+from dataclasses import dataclass
+from typing import Optional
+
+
+@dataclass(frozen=True)
+class GatewayTurnContext:
+    platform: str
+    chat_type: str
+    user_id: Optional[str]
+    chat_id: Optional[str]
+
+
+_current_turn: ContextVar[Optional[GatewayTurnContext]] = ContextVar(
+    "gateway_turn_context",
+    default=None,
+)
+
+
+def set_gateway_turn_context(
+    *,
+    platform: str,
+    chat_type: str,
+    user_id: Optional[str],
+    chat_id: Optional[str],
+) -> Token:
+    return _current_turn.set(
+        GatewayTurnContext(
+            platform=str(platform or ""),
+            chat_type=str(chat_type or ""),
+            user_id=str(user_id) if user_id else None,
+            chat_id=str(chat_id) if chat_id else None,
+        )
+    )
+
+
+def get_gateway_turn_context() -> Optional[GatewayTurnContext]:
+    return _current_turn.get()
+
+
+def reset_gateway_turn_context(token: Token) -> None:
+    _current_turn.reset(token)
