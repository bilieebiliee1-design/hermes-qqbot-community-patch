+import asyncio
+import json
+import threading
+from concurrent.futures import TimeoutError as FutureTimeoutError
+from types import SimpleNamespace
+from unittest.mock import patch
+
+import pytest
+
+from gateway.config import Platform
+from gateway.turn_context import (
+    reset_gateway_turn_context,
+    set_gateway_turn_context,
+)
+from tools.qqbot_messaging_tool import (
+    qqbot_notify_owner,
+    qqbot_send_home_group,
+)
+from toolsets import resolve_toolset
+from hermes_cli.tools_config import _get_platform_tools
+
+OWNER = "owner-openid"
+GROUP = "group-openid"
+
+
+class FakeAdapter:
+    def __init__(self):
+        self.calls = []
+        self.send_thread_id = None
+
+    async def send(self, chat_id, content, metadata=None):
+        self.send_thread_id = threading.get_ident()
+        self.calls.append((chat_id, content, metadata))
+        return SimpleNamespace(success=True, message_id="sent-ok")
+
+
+@pytest.fixture
+def configured():
+    adapter = FakeAdapter()
+    loop = asyncio.new_event_loop()
+    ready = threading.Event()
+
+    def run_loop():
+        asyncio.set_event_loop(loop)
+        ready.set()
+        loop.run_forever()
+
+    thread = threading.Thread(target=run_loop, daemon=True)
+    thread.start()
+    assert ready.wait(timeout=2)
+    runner = SimpleNamespace(
+        adapters={Platform.QQBOT: adapter},
+        _gateway_loop=loop,
+    )
+    config = {
+        "platforms": {
+            "qqbot": {
+                "extra": {
+                    "group_allow_from": GROUP,
+                    "group_owner_openids": OWNER,
+                }
+            }
+        }
+    }
+    with patch("gateway.run._gateway_runner_ref", return_value=runner), patch(
+        "hermes_cli.config.load_config", return_value=config
+    ):
+        adapter.gateway_thread_id = thread.ident
+        yield adapter
+    loop.call_soon_threadsafe(loop.stop)
+    thread.join(timeout=2)
+    loop.close()
+
+
+def _context(*, chat_type, user_id=None, chat_id=None):
+    return set_gateway_turn_context(
+        platform="qqbot",
+        chat_type=chat_type,
+        user_id=user_id,
+        chat_id=chat_id,
+    )
+
+
+def test_owner_dm_can_send_to_fixed_home_group(configured):
+    token = _context(chat_type="dm", user_id=OWNER, chat_id=OWNER)
+    try:
+        result = json.loads(qqbot_send_home_group("群公告"))
+    finally:
+        reset_gateway_turn_context(token)
+
+    assert result["success"] is True
+    assert configured.calls == [(GROUP, "群公告", {"chat_type": "group"})]
+    assert configured.send_thread_id == configured.gateway_thread_id
+
+
+@pytest.mark.parametrize(
+    ("chat_type", "user_id"),
+    [("dm", "other-openid"), ("group", OWNER)],
+)
+def test_non_owner_dm_cannot_send_to_group(configured, chat_type, user_id):
+    token = _context(chat_type=chat_type, user_id=user_id, chat_id=GROUP)
+    try:
+        result = json.loads(qqbot_send_home_group("不应发送"))
+    finally:
+        reset_gateway_turn_context(token)
+
+    assert "error" in result
+    assert configured.calls == []
+
+
+def test_no_gateway_turn_cannot_send(configured):
+    result = json.loads(qqbot_send_home_group("不应发送"))
+    assert "error" in result
+    assert configured.calls == []
+
+
+def test_home_group_can_notify_fixed_owner(configured):
+    token = _context(chat_type="group", chat_id=GROUP)
+    try:
+        result = json.loads(qqbot_notify_owner("需要你决定：是否处理该反馈？"))
+    finally:
+        reset_gateway_turn_context(token)
+
+    assert result["success"] is True
+    assert configured.calls == [
+        (OWNER, "需要你决定：是否处理该反馈？", {"chat_type": "c2c"})
+    ]
+
+
+@pytest.mark.parametrize(
+    ("chat_type", "chat_id"),
+    [("group", "other-group"), ("dm", OWNER)],
+)
+def test_other_context_cannot_notify_owner(configured, chat_type, chat_id):
+    token = _context(chat_type=chat_type, chat_id=chat_id, user_id=OWNER)
+    try:
+        result = json.loads(qqbot_notify_owner("不应发送"))
+    finally:
+        reset_gateway_turn_context(token)
+
+    assert "error" in result
+    assert configured.calls == []
+
+
+def test_message_length_is_bounded(configured):
+    token = _context(chat_type="group", chat_id=GROUP)
+    try:
+        result = json.loads(qqbot_notify_owner("x" * 1501))
+    finally:
+        reset_gateway_turn_context(token)
+
+    assert "error" in result
+    assert configured.calls == []
+
+
